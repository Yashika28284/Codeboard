{
    "name": "codeboard",
    "version": "1.0.0",
    "description": "Collaborative coding interview prep platform built with MERN stack",
    "main": "server/index.js",
    "scripts": {
        "dev": "concurrently \"npm run server\" \"npm run client\"",
        "server": "nodemon server/index.js",
        "client": "npm start --prefix client",
        "build": "npm run build --prefix client",
        "install-all": "npm install && npm install --prefix client"
    },
    "dependencies": {
        "bcryptjs": "^2.4.3",
        "concurrently": "^8.2.0",
        "cors": "^2.8.5",
        "dotenv": "^16.3.1",
        "express": "^4.18.2",
        "jsonwebtoken": "^9.0.2",
        "mongoose": "^7.6.3",
        "nodemon": "^3.0.1",
        "socket.io": "^4.7.2",
        "uuid": "^9.0.0"
    }
}